generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  name             String
  dob              DateTime?
  mobileNo         String?   @unique
  gender           String?
  email            String    @unique
  googleId         String?   @unique
  role             UserRole
  isVerified       Boolean   @default(false)
  otpAttempts      Int       @default(0)
  otpExpiry        DateTime?
  otpHash          String?
  refreshExpiresAt DateTime?
  refreshTokenHash String?
  doctor           Doctor?
  patient          Patient?
}

model Patient {
  id           String        @id @default(uuid())
  userId       String        @unique
  name         String
  dob          DateTime?
  mobileNo     String?
  gender       String?
  appointments Appointment[]
  user         User          @relation(fields: [userId], references: [id])
}

model Doctor {
  id             String             @id @default(uuid())
  name           String
  experience     Int?
  fees           Float?
  profileNote    String?
  specializesIn  String[]
  services       String[]
  userId         String             @unique
  appointments   Appointment[]
  slots          AvailabilitySlot[]
  user           User               @relation(fields: [userId], references: [id])
  recurringRules RecurringRule[]
}

model AvailabilitySlot {
  id           String         @id @default(uuid())
  sessionType  SessionType
  doctorId     String
  bookedCount  Int            @default(0)
  capacity     Int
  ruleId       String?
  startTime    DateTime
  endTime      DateTime
  durationMin  Int
  appointments Appointment[]
  doctor       Doctor         @relation(fields: [doctorId], references: [id])
  rule         RecurringRule? @relation(fields: [ruleId], references: [id])
}

model Appointment {
  id              String            @id @default(uuid())
  appointmentDate DateTime
  complaint       String
  visitType       String
  weight          Float?
  recordedAge     Int?
  status          AppointmentStatus
  patientId       String
  doctorId        String
  slotId          String
  consultingType  ConsultingType
  appointmentTime DateTime
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  patient         Patient           @relation(fields: [patientId], references: [id])
  slot            AvailabilitySlot  @relation(fields: [slotId], references: [id])
}

model RecurringRule {
  id          String             @id @default(uuid())
  doctorId    String
  weekdayMask Int
  startMin    Int
  capacity    Int
  validFrom   DateTime
  validUntil  DateTime?
  sessionType SessionType
  durationMin Int
  endMin      Int?
  isStream    Boolean            @default(true)
  slots       AvailabilitySlot[]
  doctor      Doctor             @relation(fields: [doctorId], references: [id])
}

enum UserRole {
  PATIENT
  DOCTOR
}

enum SessionType {
  ONLINE
  OFFLINE
}

enum AppointmentStatus {
  BOOKED
  CANCELLED
  COMPLETED
}

enum ConsultingType {
  REGULAR
  REVISIT
  FOLLOW_UP
}
